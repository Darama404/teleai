# ═══════════════════════════════════════════════════════════
#  Soy Oncall Bot (Polling Script) — .env template
#  Copy ke .env lalu isi sesuai kebutuhan
# ═══════════════════════════════════════════════════════════

# ── Telegram Bot API ─────────────────────────────────────────
# Token dan Username Bot (untuk polling via Bot API)
BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ
BOT_USERNAME=MyCool_Bot

# ── Telethon API Service ─────────────────────────────────────
# Endpoint ke local service Telethon
TELETHON_URL=http://127.0.0.1:8000
# Sesuai dengan API_TOKEN di telethon/.env
API_TOKEN=your_secret_api_token_here

# ── Teams & Users ────────────────────────────────────────────
# Username yang di-monitor di group (yang di-tag oleh client)
# Pisah spasi, tanpa @ (sesuai iterasi di bash script)
TEAM_USERNAMES="yourusername otheradmin"

# Pengecualian: Jika sender ada di list ini, bot tidak akan jalan
# Pisah koma, tanpa @
SKIP_USERS=internaluser1,internaluser2,bossuser

# ── Group IDs ────────────────────────────────────────────────
# Group internal sysadmin (untuk forward notifikasi)
INTERNAL_CHAT_ID=-100123456789

# Sysadmin chat ID (bot tidak akan respond di sini)
SYSADMIN_CHAT_ID=-100123456789

# ── Developer tag (untuk pesan out-of-scope) ─────────────────
# Contoh: @devusername atau @devteam
DEV_TAG=@devusername

# ── Groq AI ──────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model untuk text scope detection
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Model untuk image/vision analysis (sama atau bisa beda)
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Human-like Delay ─────────────────────────────────────────
# Delay (detik) sebelum bot reply — agar terlihat natural
DELAY_MIN=3.0
DELAY_MAX=7.0

# ── Sleep Hours (WIB / Jakarta) ──────────────────────────────
# Format HH:MM — support cross-midnight (22:00-06:00)
SLEEP_HOUR_START=22:00
SLEEP_HOUR_END=06:00
TZ_JAKARTA=Asia/Jakarta

# ── Pushover (hanya aktif saat sleep hours) ──────────────────
PUSHOVER_TOKEN=your_pushover_app_token
PUSHOVER_USER=your_pushover_user_key

# Device escalation (kosongkan jika tidak dipakai)
PUSHOVER_DEVICE_PRIMARY=iphone_andi
PUSHOVER_DEVICE_BACKUP=android_budi
PUSHOVER_DEVICE_HIGHER=iphone_manager
PUSHOVER_DEVICE_HIGHEST=

# Timeout tiap level (detik) sebelum escalate ke level berikutnya
PUSHOVER_WAIT_PRIMARY=60
PUSHOVER_WAIT_BACKUP=60
PUSHOVER_WAIT_HIGHER=300
PUSHOVER_WAIT_HIGHEST=600
