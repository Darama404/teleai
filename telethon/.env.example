# ═══════════════════════════════════════════════════════════
#  Soy Oncall Bot (Telethon Service) — .env template
#  Copy ke .env lalu isi sesuai kebutuhan
# ═══════════════════════════════════════════════════════════

# ── Telethon / Telegram API ──────────────────────────────────
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Session names (pisah koma jika multi-session)
# File session harus ada di folder sessions/<nama>.session
SESSIONS=soy

# ── API Token (untuk endpoint Flask) ────────────────────────
# Jika diisi, client harus mengirim header X-API-Token
API_TOKEN=your_secret_api_token_here